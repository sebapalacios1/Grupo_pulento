{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: gcc.exe compilar archivo activo",
            "command": "C:\\msys64\\ucrt64\\bin\\gcc.exe",
            "args": [
                "-finput-charset=UTF-8",
                "-fexec-charset=cp850",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Tarea de compilación nativa corregida para rutas complejas."
        }
    ],
    "version": "2.0.0"
}